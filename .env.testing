# ============================================
# LARAVEL APPLICATION
# ============================================
APP_NAME="Laravel Testing"
APP_ENV=testing
APP_KEY=base64:CpJeaxAyduoZX2aJK/TI3nIKZ6GG7R2bANeFqLEFydo=
APP_DEBUG=true
APP_URL=http://localhost:8000

# FRONTEND URLs (comentadas para testing)
# FRONTEND_URL=http://localhost:3000

# ============================================
# LOCALIZATION
# ============================================
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ============================================
# MAINTENANCE MODE
# ============================================
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# ============================================
# PHP SETTINGS
# ============================================
# PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=4  # Reducido para testing más rápido

# ============================================
# LOGGING
# ============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# DATABASE - MYSQL (USANDO TU PUERTO 33601)
# ============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=33601
DB_DATABASE=test_app_testing  # ¡BASE DE DATOS DIFERENTE!
DB_USERNAME=root
DB_PASSWORD=

# ============================================
# SESSION (USANDO ARRAY PARA TESTING)
# ============================================
SESSION_DRIVER=array  # Importante: array en lugar de database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ============================================
# BROADCASTING
# ============================================
BROADCAST_CONNECTION=log

# ============================================
# FILESYSTEM
# ============================================
FILESYSTEM_DISK=local

# ============================================
# QUEUE (USANDO SYNC PARA TESTING)
# ============================================
QUEUE_CONNECTION=sync  # Importante: sync en lugar de database

# ============================================
# CACHE (USANDO ARRAY PARA TESTING)
# ============================================
CACHE_STORE=array  # Importante: array en lugar de database
# CACHE_PREFIX=

# ============================================
# MEMCACHED
# ============================================
MEMCACHED_HOST=127.0.0.1

# ============================================
# REDIS
# ============================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================
# MAIL (USANDO ARRAY PARA TESTING)
# ============================================
MAIL_MAILER=array  # Importante: array en lugar de log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="testing@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# AWS
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================
# VITE / FRONTEND
# ============================================
VITE_APP_NAME="${APP_NAME}"
# VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
# VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
# VITE_PUSHER_HOST="${PUSHER_HOST}"
# VITE_PUSHER_PORT="${PUSHER_PORT}"
# VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
# VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ============================================
# SANCTUM (SI LO USAS)
# ============================================
SANCTUM_STATEFUL_DOMAINS=localhost:8000
SESSION_DOMAIN=localhost